            images[2] = "./images/newspaper.png"
            images[3] = "./images/envelope.png"
            images[4] = "./images/users.png"
            images[5] = "./users/noImg.jpg"


            // start preloading
            for (i = 0; i <= 5; i++)
            {
                imageObj[i] = new Image();
                imageObj[i].src = images[i];
            }
        }
        $(document).ready(imgPreload);

